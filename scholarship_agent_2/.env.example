# ─────────────────────────────────────────────────────────────
# Scholarship Agent — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL
DATABASE_URL=postgresql://scholarship_user:scholarship_pass@localhost:5432/scholarship_db
DB_ECHO=false

# Email — SMTP (used when SENDGRID_API_KEY is not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=nguzhukiet0717@gmail.com

# Email — SendGrid (optional, takes priority over SMTP)
SENDGRID_API_KEY=

# Web search (optional — enables search_web_scholarships tool)
SERPER_API_KEY=

# Redis (optional caching)
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO
